#!/data/data/com.termux/files/usr/bin/sh
# UOM phone one-shot: packages, sshd, tools, reverse tunnel
set -u
BASE="${UOM_BASE:-http://192.168.40.90:8765}"
export UOM_LAPTOP_IP="${UOM_LAPTOP_IP:-192.168.40.90}"
export UOM_LAPTOP_USER="${UOM_LAPTOP_USER:-alpine}"
export UOM_REV_PORT="${UOM_REV_PORT:-31415}"

echo "[UOM] downloading bootstrap..."
curl -fsSL "$BASE/b.sh" -o "$HOME/b.sh" || { echo "FAIL: download b.sh"; exit 1; }
chmod +x "$HOME/b.sh"
sh "$HOME/b.sh" || { echo "FAIL: bootstrap"; exit 1; }

echo "[UOM] installing orchestrator tools..."
mkdir -p "$HOME/src/universal-omni-master/tools"
cd "$HOME/src/universal-omni-master/tools" || exit 1
curl -fsSL "$BASE/t.tgz" | tar -xz || { echo "FAIL: tools tgz"; exit 1; }
chmod +x *.sh 2>/dev/null || true

# publish termux user to laptop (best-effort, may ask password once)
if [ -f "$HOME/.uom-termux-user" ] || id -un >/dev/null 2>&1; then
  TU=$(id -un)
  echo "$TU" > "$HOME/.uom-termux-user"
  ssh -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=accept-new \
    "${UOM_LAPTOP_USER}@${UOM_LAPTOP_IP}" "printf '%s\n' '$TU' > ~/.uom-termux-user" 2>/dev/null || true
fi

echo "[UOM] starting reverse tunnel (leave running)..."
if [ -x "$HOME/bin/uom-reverse-ssh.sh" ]; then
  exec sh "$HOME/bin/uom-reverse-ssh.sh"
fi
# fallback one-shot reverse
sshd 2>/dev/null || true
exec ssh -N -o ExitOnForwardFailure=yes -o ServerAliveInterval=20 \
  -o StrictHostKeyChecking=accept-new \
  -R "${UOM_REV_PORT}:127.0.0.1:8022" \
  "${UOM_LAPTOP_USER}@${UOM_LAPTOP_IP}"
