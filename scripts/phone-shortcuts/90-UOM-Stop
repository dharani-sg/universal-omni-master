#!/bin/sh
# NAME: 90-UOM-Stop
# PURPOSE: Clean shutdown of guest + QEMU — requires "STOP" confirmation
# VERSION: 2.1.0
# DEPENDS: uom-lib.sh, uom-qemu-phone, ssh
# SAFE: destructive (stops QEMU, never deletes disks)
# TESTED: PASS 2026-07-18
#
# Widget shortcut: requires user to TYPE exactly "STOP" to proceed.

set -u
. "${HOME}/bin/uom-widget-lib.sh"

SHUTDOWN_TIMEOUT=30

echo "=========================================="
echo " UOM STOP"
echo "=========================================="
echo ""

# Check if VM is running
if ! uom_qemu_running; then
    echo "VM is not running. Nothing to stop."
    exit 0
fi

echo "QEMU detected (pid=$UOM_QEMU_PID, tier=$UOM_QEMU_TIER)."
echo "This will shut down the Alpine guest and stop QEMU."
echo "Type STOP to confirm (anything else cancels):"
echo -n "> "
read -r _confirm </dev/tty 2>/dev/null || read -r _confirm

if [ "${_confirm}" != "STOP" ]; then
    echo "Cancelled."
    exit 1
fi

echo ""
echo "--- Step 1: Clean guest shutdown ---"

# Try SSH poweroff first
if uom_guest_ssh 'doas poweroff' 2>/dev/null; then
    echo "Guest poweroff command sent."
elif uom_guest_ssh 'sudo poweroff' 2>/dev/null; then
    echo "Guest poweroff command sent (sudo)."
else
    echo "Could not SSH guest for clean shutdown."
    echo "Guest may already be down or unreachable."
fi

# Wait for guest to shut down (bounded)
echo "Waiting for guest to shut down (timeout=${SHUTDOWN_TIMEOUT}s)..."
_count=0
while [ "${_count}" -lt "${SHUTDOWN_TIMEOUT}" ]; do
    if ! uom_guest_ssh 'echo OK' 2>/dev/null | grep -q "OK"; then
        echo "Guest shut down after ${_count}s."
        break
    fi
    sleep 2
    _count=$((_count + 2))
done

if [ "${_count}" -ge "${SHUTDOWN_TIMEOUT}" ]; then
    echo "Guest still responding after ${SHUTDOWN_TIMEOUT}s."
    echo "Proceeding with QEMU stop..."
fi

echo ""
echo "--- Step 2: Stop QEMU ---"
"${UOM_QEMU_LAUNCHER}" stop

echo ""
echo "--- Step 3: Verify ---"
if ! uom_qemu_running; then
    echo "VM stopped successfully."
else
    echo "WARNING: VM may still be running. Check manually."
fi

echo ""
echo "Done."
