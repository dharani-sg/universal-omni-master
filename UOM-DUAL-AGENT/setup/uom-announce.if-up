#!/bin/sh
# /etc/network/if-up.d/uom-announce — install via phase2-laptop.sh
# Announce laptop IP into UOM agent state on network connect.
# Hardcoded owner path: if-up runs as root without user env.

REPO_DIR="/home/alpine/src/universal-omni-master"
OWNER="alpine"
[ -d "$REPO_DIR/.uom-agent" ] || exit 0

MY_IP=$(ip route get 8.8.8.8 2>/dev/null | awk '/src/{print $7; exit}')
[ -z "$MY_IP" ] && exit 0

echo "$MY_IP" > "$REPO_DIR/.uom-agent/laptop.ip"
chown "$OWNER:$OWNER" "$REPO_DIR/.uom-agent/laptop.ip" 2>/dev/null || true

# Git as repo owner (not root)
su -s /bin/sh "$OWNER" -c "
  cd '$REPO_DIR' || exit 0
  git add .uom-agent/laptop.ip 2>/dev/null || exit 0
  git diff --cached --quiet && exit 0
  git commit -m \"heartbeat: laptop IP announce $MY_IP \$(date -Iseconds 2>/dev/null || date)\" 2>/dev/null || true
  git push origin main 2>/dev/null || true
" 2>/dev/null || true
