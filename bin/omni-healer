#!/bin/sh
# omni-healer — parallel self-healing watchdog daemon (M8).
set -u

_OMNI_ROOT="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)"
. "$_OMNI_ROOT/src/core/logging.sh"
. "$_OMNI_ROOT/src/healer/common.sh"
. "$_OMNI_ROOT/src/healer/storage.sh"
. "$_OMNI_ROOT/src/healer/services.sh"
. "$_OMNI_ROOT/src/healer/gpu.sh"
. "$_OMNI_ROOT/src/gpu/interface.sh" 2>/dev/null || true

healer_load_conf

_children=""
_spawn() { "$@" & _children="$_children $!"; }

_shutdown() {
    healer_emit "healer" "shutdown" "omni-healer stopping"
    # L11 fix: use printf + read to iterate pids safely (IFS-immune)
    echo "$_children" | tr ' ' '\n' | while read -r _pid; do
        [ -n "$_pid" ] && kill "$_pid" 2>/dev/null || true
    done
    rm -f "$HEALER_PIDFILE"
    exit 0
}

case "${1:-run}" in
    run)
        if [ -f "$HEALER_PIDFILE" ] && kill -0 "$(cat "$HEALER_PIDFILE")" 2>/dev/null; then
            echo "omni-healer already running (pid $(cat "$HEALER_PIDFILE"))" >&2
            exit 1
        fi
        printf '%s\n' "$$" > "$HEALER_PIDFILE"
        trap _shutdown INT TERM

        healer_emit "healer" "init" "omni-healer started (storage=$HEALER_STORAGE_MONITOR services=$HEALER_SERVICE_MONITOR gpu=$HEALER_GPU_RESTORE)"
        [ "$HEALER_STORAGE_MONITOR" = "1" ] && _spawn healer_storage_loop
        [ "$HEALER_SERVICE_MONITOR" = "1" ] && _spawn healer_services_loop
        [ "$HEALER_GPU_RESTORE" = "1" ]     && _spawn healer_gpu_loop
        wait
        ;;
    status)
        if [ -f "$HEALER_PIDFILE" ] && kill -0 "$(cat "$HEALER_PIDFILE")" 2>/dev/null; then
            echo "running (pid $(cat "$HEALER_PIDFILE"))"; exit 0
        fi
        echo "not running"; exit 1
        ;;
    stop)
        [ -f "$HEALER_PIDFILE" ] && kill "$(cat "$HEALER_PIDFILE")" 2>/dev/null
        rm -f "$HEALER_PIDFILE"; echo "stopped"
        ;;
    test-emit)
        HEALER_AUDIT_LOG="${2:-/tmp/omni-audit-test.json}"
        healer_emit "healer" "selftest" 'quote " and backslash \ survive escaping'
        healer_backoff 0; echo; healer_backoff 3; echo; healer_backoff 99; echo
        ;;
    *)
        echo "usage: omni-healer {run|status|stop|test-emit}" >&2
        exit 2
        ;;
esac
