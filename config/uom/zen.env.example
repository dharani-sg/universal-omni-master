# zen.env.example — UOM Zen Loop Environment Configuration
# Copy to ~/.config/uom/zen.env and adjust as needed.
# NEVER commit the real zen.env (contains runtime state).

# Auth policy: strict-no-auth = no API keys required
UOM_ZEN_AUTH_POLICY=strict-no-auth

# Model status: READY_ANONYMOUS = all models verified free
ZEN_MODEL_STATUS=READY_ANONYMOUS

# Good pool models (coding/reasoning tasks)
UOM_OPENCODE_MODEL_GOOD=deepseek-v4-flash-free
UOM_OPENCODE_MODEL_NORMAL=big-pickle

# Runtime: phone-qemu | laptop | phone-termux
UOM_RUNTIME=phone-qemu

# Agent mode: phone-solo | dual | laptop-primary
UOM_AGENT_MODE=phone-solo

# Transport: anonymous-api-fallback | native-serve-attach
UOM_OPENCODE_TRANSPORT=anonymous-api-fallback
