    case "$1" in
        --apply)      DEPLOY_DRYRUN=0 ;;
        --distro)     shift; DEPLOY_DISTRO="$1" ;;
        --fs)         shift; DEPLOY_FS="$1" ;;
        --disk)       shift; DEPLOY_DISK="$1" ;;
        --target)     shift; DEPLOY_TARGET="$1" ;;
        --init)       shift; DEPLOY_INIT="$1" ;;
        --hostname)   shift; DEPLOY_HOSTNAME="$1" ;;
        --user)       shift; DEPLOY_USER="$1" ;;
        --encrypt)    DEPLOY_ENCRYPT=1 ;;
        *) log_error "Unknown: $1"; exit 2 ;;
    esac
    shift
done

export DEPLOY_TARGET DEPLOY_DISK DEPLOY_FS DEPLOY_DISTRO DEPLOY_INIT
export DEPLOY_ENCRYPT DEPLOY_HOSTNAME DEPLOY_USER DEPLOY_DRYRUN DEPLOY_LOCALE

# ── Dispatch ──────────────────────────────────────────────────────────────────
case "$COMMAND" in
    help|--help|-h)
        cat << HELP
omni-deploy — Universal Omni-Master Installer

Usage: omni-deploy <command> [options]

Commands:
  plan        Show deployment plan without executing
  preflight   Run hardware compatibility checks only
  install     Full install (all phases)
  rollback    Undo a failed installation
  status      Show current phase state
  help        Show this help

Options:
  --apply       Execute changes (default: dry-run, prints only)
  --distro N    $(deploy_list_distros | tr '\n' '|' | sed 's/|$//')
  --fs T        ext4|btrfs|xfs|f2fs (default: btrfs)
  --disk D      target disk, e.g. sda or nvme0n1
  --init I      $(deploy_list_inits | tr '\n' '|' | sed 's/|$//')
  --hostname N  hostname (default: omni-linux)
  --user N      create non-root user
  --encrypt     enable LUKS2 full-disk encryption
  --target DIR  mount point (default: /mnt)
HELP
        exit 0
        ;;

    plan)
        printf '\n══ DEPLOYMENT PLAN ══\n'
        printf '  distro:     %s\n' "${DEPLOY_DISTRO:-<not set>}"
        printf '  filesystem: %s\n' "$DEPLOY_FS"
        printf '  disk:       %s\n' "${DEPLOY_DISK:-<not set>}"
        printf '  init:       %s\n' "${DEPLOY_INIT:-<auto-detect>}"
        printf '  encrypt:    %s\n' "$DEPLOY_ENCRYPT"
        printf '  hostname:   %s\n' "$DEPLOY_HOSTNAME"
        printf '  target:     %s\n' "$DEPLOY_TARGET"
        printf '  mode:       %s\n' "$([ "$DEPLOY_DRYRUN" -eq 1 ] && echo DRY-RUN || echo APPLY)"
        printf '  root fs:    %s\n' "$(fs_root_type 2>/dev/null || echo unknown)"
        printf '  GPU hybrid: %s\n' "$(detect_gpu_hybrid 2>/dev/null || echo unknown)"
        preflight_check 2>/dev/null || true
        exit 0
        ;;

    preflight)
        preflight_check
        ;;

    status)
        deploy_state_get
        ;;

    rollback)
        rollback_full "$DEPLOY_TARGET"
        ;;

    install)
        printf '\n══════════════════════════════════════\n'
        printf '  Universal Omni-Master — Installation\n'
        printf '══════════════════════════════════════\n'

        [ "$DEPLOY_DRYRUN" -eq 1 ] && \
            printf '\n[DRY-RUN] No changes will be made. Use --apply.\n\n'

        # Interactive selection
        if [ -z "$DEPLOY_DISTRO" ]; then
            printf '\nSelect distribution:\n'; deploy_list_distros
            printf 'Choice: '; read -r DEPLOY_DISTRO
        fi
        if [ -z "$DEPLOY_DISK" ]; then
            printf '\nAvailable disks:\n'
            storage_enumerate 2>/dev/null || lsblk -d -o NAME,SIZE 2>/dev/null
            printf 'Target disk (e.g. sda): '; read -r DEPLOY_DISK
        fi
        if [ -z "$DEPLOY_INIT" ]; then
            DEPLOY_INIT=$(deploy_auto_detect_init "$DEPLOY_DISTRO")
            log_info "Auto-detected init: $DEPLOY_INIT"
        fi

        # Plan display
        printf '\n══ PLAN ══\n'
        printf '  Distro:     %s (init: %s)\n' "$DEPLOY_DISTRO" "$DEPLOY_INIT"
        printf '  Filesystem: %s\n' "$DEPLOY_FS"
        printf '  Disk:       /dev/%s\n' "$DEPLOY_DISK"
        printf '  Encrypt:    %s\n' "$DEPLOY_ENCRYPT"
        printf '  Hostname:   %s\n' "$DEPLOY_HOSTNAME"

        [ "$DEPLOY_DRYRUN" -eq 1 ] && { printf '\n[DRY-RUN] Remove --apply to exit.\n'; exit 0; }

        # Preflight
        deploy_state_init
        preflight_check || exit 1

        # Backup partition table BEFORE any modifications (rollback safety)
        rollback_partition_backup "$DEPLOY_DISK"

        # Format + subvols
        deploy_state_set "partitioning"
        partition_format "$DEPLOY_DISK" "$DEPLOY_FS" || { rollback_full; exit 1; }
        [ "$DEPLOY_FS" = "btrfs" ] && \
            { partition_btrfs_subvols "$DEPLOY_DISK" || { rollback_full; exit 1; }; }

        # Mount
        deploy_state_set "mounting"
        mkdir -p "$DEPLOY_TARGET"
        mount "/dev/${DEPLOY_DISK}2" "$DEPLOY_TARGET" 2>/dev/null || \
            mount "/dev/$DEPLOY_DISK" "$DEPLOY_TARGET" || \
            { log_error "cannot mount target"; rollback_full; exit 1; }
        partition_generate_fstab "$DEPLOY_DISK" "$DEPLOY_FS"

        # Bootstrap
        deploy_state_set "bootstrap"
        bootstrap_install "$DEPLOY_DISTRO" "$DEPLOY_TARGET" || \
            { rollback_full; exit 1; }

        # Chroot setup
        deploy_state_set "chroot_setup"
        chroot_fix_elf_interp "$DEPLOY_TARGET"   # musl→glibc ELF fix
        chroot_mount "$DEPLOY_TARGET"
        chroot_copy_resolv "$DEPLOY_TARGET"

        # Configure
        deploy_state_set "configure"
        deploy_set_hostname "$DEPLOY_HOSTNAME" "$DEPLOY_TARGET"
        deploy_set_locale "$DEPLOY_TARGET" "$DEPLOY_INIT"
        [ -n "$DEPLOY_USER" ] && deploy_create_user "$DEPLOY_TARGET"
        [ "$DEPLOY_INIT" != "systemd" ] && deploy_setup_dbus "$DEPLOY_TARGET"
        deploy_install_healer "$DEPLOY_TARGET" "$DEPLOY_INIT"
        deploy_install_snapshot "$DEPLOY_TARGET" "$DEPLOY_INIT" "$DEPLOY_DISTRO"
        deploy_snapshot_enable_periodic "$DEPLOY_TARGET" "$DEPLOY_INIT"
        deploy_enable_services "$DEPLOY_TARGET" "$DEPLOY_INIT" \
            NetworkManager dbus sshd

        # GPU + no-PM policies (from M4/M5)
        deploy_state_set "policies"
        deploy_install_gpu_policy 2>/dev/null || true
        deploy_install_nopm_policy 2>/dev/null || true
        deploy_install_dgpu_manager 2>/dev/null || true

        # Initramfs rebuild (critical — without this, kernel panics on boot)
        deploy_state_set "initramfs"
        deploy_rebuild_initramfs "$DEPLOY_TARGET" "$DEPLOY_DISTRO"

        # Bootloader
        deploy_state_set "bootloader"
        deploy_install_bootloader || { rollback_full; exit 1; }

        # Verify
        deploy_state_set "verify"
        chroot_unmount "$DEPLOY_TARGET"
        chroot_unfix_elf_interp
        deploy_verify "$DEPLOY_TARGET"
        _rc=$?

        if [ "$_rc" -eq 0 ]; then
            deploy_state_set "complete"
            printf '\n══ DEPLOYMENT COMPLETE ══\n'
            printf 'Target: %s\n' "$DEPLOY_TARGET"
            printf 'Reboot and select from your bootloader.\n\n'
        else
            deploy_state_set "failed"
            log_error "Verification failed — run: omni-deploy rollback"
            exit 1
        fi
        ;;

    *)
        log_error "Unknown command: $COMMAND"
        exit 2
        ;;
esac

}

__main_omni_healer() {
# omni-healer — parallel self-healing watchdog daemon (M8).


healer_load_conf
healer_ensure_paths

_children=""
_spawn() { "$@" & _children="$_children $!"; }

_shutdown() {
    healer_emit "healer" "shutdown" "omni-healer stopping"
    # L11 fix: use printf + read to iterate pids safely (IFS-immune)
    echo "$_children" | tr ' ' '\n' | while read -r _pid; do
        [ -n "$_pid" ] && kill "$_pid" 2>/dev/null || true
    done
    rm -f "$HEALER_PIDFILE"
    exit 0
}

case "${1:-run}" in
    run)
        if [ -f "$HEALER_PIDFILE" ] && kill -0 "$(cat "$HEALER_PIDFILE")" 2>/dev/null; then
            echo "omni-healer already running (pid $(cat "$HEALER_PIDFILE"))" >&2
            exit 1
        fi
        printf '%s\n' "$$" > "$HEALER_PIDFILE"
        trap _shutdown INT TERM

        healer_emit "healer" "init" "omni-healer started (storage=$HEALER_STORAGE_MONITOR services=$HEALER_SERVICE_MONITOR gpu=$HEALER_GPU_RESTORE)"
        [ "$HEALER_STORAGE_MONITOR" = "1" ] && _spawn healer_storage_loop
        [ "$HEALER_SERVICE_MONITOR" = "1" ] && _spawn healer_services_loop
        [ "$HEALER_GPU_RESTORE" = "1" ]     && _spawn healer_gpu_loop
        wait
        ;;
    status)
        if [ -f "$HEALER_PIDFILE" ] && kill -0 "$(cat "$HEALER_PIDFILE")" 2>/dev/null; then
            echo "running (pid $(cat "$HEALER_PIDFILE"))"; exit 0
        fi
        echo "not running"; exit 1
        ;;
    stop)
        [ -f "$HEALER_PIDFILE" ] && kill "$(cat "$HEALER_PIDFILE")" 2>/dev/null
        rm -f "$HEALER_PIDFILE"; echo "stopped"
        ;;
    test-emit)
        HEALER_AUDIT_LOG="${2:-/tmp/omni-audit-test.json}"
        healer_emit "healer" "selftest" 'quote " and backslash \ survive escaping'
        healer_backoff 0; echo; healer_backoff 3; echo; healer_backoff 99; echo
        ;;
    *)
        echo "usage: omni-healer {run|status|stop|test-emit}" >&2
        exit 2
        ;;
esac

}

__main_omni_snapshot() {
# bin/omni-snapshot — Btrfs snapshot lifecycle + atomic rollback CLI.


snap_load_conf

_usage() {
    cat << HELP
omni-snapshot — Btrfs Snapshot Lifecycle + Rollback

Lifecycle:
  create <category> [reason]   pretxn|hourly|daily|weekly|manual|emergency
  create --reason <reason>     hook-compatible form
  list                         list managed snapshot names
  prune                        per-category retention (+ boot-entry sync)
  sweep [days]                 remove M8 emergency orphans
  periodic                     run due periodic snapshots
  status                       counts + free space + boot entries

Boot entries:
  boot-entry add <snap>        add bootloader entry
  boot-entry list              list omni-snap entries
  boot-entry remove <snap>     remove entry
  boot-entry sync              drop entries for deleted snapshots

Rollback:
  restore <snap>               stage restore (RW clone + boot entry)
  rollback <snap>              alias of restore
  restore-cancel               undo a staged restore
  boot-once <snap>             boot snapshot once, then revert
  help
HELP
}

_cmd_status() {
    _snap_require_btrfs / || return 0
    printf 'Snapshot categories:\n'
    for _cat in pretxn hourly daily weekly manual emergency; do
        _n=$(snap_list_names | grep -c "_${_cat}" 2>/dev/null || echo 0)
        printf '  %-12s %3d\n' "$_cat" "$_n"
    done
    printf '\nBoot entries:\n'; snap_boot_entry_list 2>/dev/null || true
    printf '\nFree space at /:\n'; df -Ph / 2>/dev/null | tail -1
}

COMMAND="${1:-help}"
[ $# -gt 0 ] && shift || true

case "$COMMAND" in
    create)
        if [ "${1:-}" = "--reason" ]; then
            _raw="${2:-manual}"
            _cat=$(printf '%s' "$_raw" | cut -d'-' -f1)
            _rsn=$(printf '%s' "$_raw" | cut -d'-' -f2-)
            [ "$_cat" = "$_rsn" ] && _rsn=""
        else
            _cat="${1:-manual}"; _rsn="${2:-}"
        fi
        snap_create "$_cat" "$_rsn" ;;
    list)     snap_list_names ;;
    prune)    snap_prune ;;
    sweep)    healer_snapshot_prune_orphans "${1:-}" ;;
    periodic) snap_run_periodic ;;
    status)   _cmd_status ;;
    boot-entry)
        _sub="${1:-list}"; shift 2>/dev/null || true
        case "$_sub" in
            add)    snap_boot_entry_add "${1:?snap name required}" ;;
            list)   snap_boot_entry_list ;;
            remove) snap_boot_entry_remove "${1:?snap name required}" ;;
            sync)   snap_boot_entry_sync ;;
            *)      printf 'unknown boot-entry sub: %s\n' "$_sub" >&2; exit 2 ;;
        esac ;;
    restore|rollback)
        snap_restore "${1:?snapshot name required}" ;;
    restore-cancel)
        snap_restore_cancel ;;
    boot-once)
        snap_boot_once "${1:?snapshot name required}" ;;
    help|--help|-h) _usage; exit 0 ;;
    *) printf 'omni-snapshot: unknown command: %s\n' "$COMMAND" >&2; _usage >&2; exit 2 ;;
esac

}

# ===== DISPATCHER =====
_prog=$(basename "$0" .sh)
case "$_prog" in
    omni-detect)   __main_omni_detect   "$@"; exit $? ;;
    omni-service)  __main_omni_service  "$@"; exit $? ;;
    omni-boot)     __main_omni_boot     "$@"; exit $? ;;
    omni-gpu)      __main_omni_gpu      "$@"; exit $? ;;
    omni-storage)  __main_omni_storage  "$@"; exit $? ;;
    omni-audit)    __main_omni_audit    "$@"; exit $? ;;
    omni-deploy)   __main_omni_deploy   "$@"; exit $? ;;
    omni-healer)   __main_omni_healer   "$@"; exit $? ;;
    omni-snapshot) __main_omni_snapshot "$@"; exit $? ;;
esac

_sub="${1:-help}"; [ $# -gt 0 ] && shift
case "$_sub" in
    detect)   __main_omni_detect   "$@" ;;
    service)  __main_omni_service  "$@" ;;
    boot)     __main_omni_boot     "$@" ;;
    gpu)      __main_omni_gpu      "$@" ;;
    storage)  __main_omni_storage  "$@" ;;
    audit)    __main_omni_audit    "$@" ;;
    deploy)   __main_omni_deploy   "$@" ;;
    healer)   __main_omni_healer   "$@" ;;
    snapshot) __main_omni_snapshot "$@" ;;
    help|--help|-h)
        printf 'omni-monolith — Universal Omni-Master (bundled)\n'
        printf 'Usage: %s <tool> [args]\n' "$(basename "$0")"
        printf 'Tools: detect service boot gpu storage audit deploy healer snapshot\n'
        printf 'Or symlink this file to a tool name.\n' ;;
    *) printf 'omni-monolith: unknown tool: %s\n' "$_sub" >&2; exit 2 ;;
esac
