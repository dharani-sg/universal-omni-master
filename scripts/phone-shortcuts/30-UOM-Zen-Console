#!/bin/sh
# NAME: 30-UOM-Zen-Console
# PURPOSE: Open Zen Loop console in guest Alpine via tmux
# VERSION: 2.1.0
# DEPENDS: uom-lib.sh, uom-qemu-phone, ssh, tmux
# SAFE: modifies-state (starts QEMU if needed, creates tmux session)
# TESTED: PASS 2026-07-18
#
# Widget shortcut: SSH into guest and attach to zen tmux session.

set -u
. "${HOME}/bin/uom-widget-lib.sh"

ZEN_SESSION="uom-zen-phone"

# Ensure QEMU is running
if ! uom_ensure_qemu; then
    echo "[zen-console] ERROR: QEMU not available"
    exit 1
fi

# Wait for SSH (bounded)
echo "[zen-console] Waiting for guest SSH..."
_count=0
while [ "${_count}" -lt 60 ]; do
    if uom_guest_ssh 'echo OK' 2>/dev/null | grep -q "OK"; then
        break
    fi
    sleep 3
    _count=$((_count + 3))
done
if [ "${_count}" -ge 60 ]; then
    echo "[zen-console] ERROR: Guest SSH timeout"
    exit 1
fi

# Check if zen session exists in guest
if uom_guest_ssh "tmux has-session -t ${ZEN_SESSION} 2>/dev/null"; then
    echo "[zen-console] Attaching to existing zen session..."
else
    echo "[zen-console] Zen session not found. Creating..."
    # Create tmux session in background in the guest
    uom_guest_ssh "tmux new-session -d -s ${ZEN_SESSION} -n status 'echo Zen Loop session; cd ~/src/universal-omni-master && exec sh'" 2>/dev/null || true
    sleep 2
fi

# Interactive SSH into guest, attach to zen tmux
exec ssh -tt ${UOM_SSH_OPTS} ${UOM_GUEST_USER}@127.0.0.1 \
    "tmux attach -t ${ZEN_SESSION} 2>/dev/null || tmux new-session -s ${ZEN_SESSION}"
