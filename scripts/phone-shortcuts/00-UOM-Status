#!/bin/sh
# 00-UOM-Status — Quick UOM system status check
# Widget shortcut: shows QEMU, guest, tmux, and zen status at a glance.
# POSIX sh. Read-only (no mutations). Idempotent.

set -u

QEMU_LAUNCHER="${HOME}/bin/uom-qemu-phone"
GUEST_PORT="2222"
GUEST_USER="uom"
GUEST_SSH_OPTS="-p ${GUEST_PORT} -o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/dev/null"
GUEST_SSH="ssh ${GUEST_SSH_OPTS} ${GUEST_USER}@127.0.0.1"

echo "=========================================="
echo " UOM Status"
echo " $(date '+%Y-%m-%d %H:%M:%S')"
echo "=========================================="
echo ""

# QEMU status
echo "--- QEMU ---"
"${QEMU_LAUNCHER}" status 2>/dev/null || echo "Status check failed"
echo ""

# Guest SSH
echo "--- Guest SSH ---"
if ${GUEST_SSH} 'echo OK' 2>/dev/null | grep -q "OK"; then
    echo "SSH:    OK"
    _info=$(${GUEST_SSH} "hostname; id; uptime" 2>/dev/null || echo "info unavailable")
    echo "${_info}"
else
    echo "SSH:    UNREACHABLE"
fi
echo ""

# Guest tmux
echo "--- Guest tmux ---"
${GUEST_SSH} "tmux ls 2>&1" 2>/dev/null || echo "(no tmux or guest unreachable)"
echo ""

# Host tmux
echo "--- Host tmux ---"
tmux ls 2>&1 || echo "(no host tmux sessions)"
echo ""

# Disk
echo "--- Disk ---"
qemu-img info "${HOME}/uom-vm/images/uom-phone.qcow2" 2>/dev/null | grep -E "virtual|disk size" || echo "(no disk)"
echo ""

# Processes
echo "--- Processes ---"
ps -A -o USER,PID,ARGS 2>/dev/null | grep -E "[q]emu|[o]pencode|[u]om-orch" || echo "(none found)"
echo ""

echo "=========================================="
