#!/bin/sh
# NAME: 10-UOM-Start
# PURPOSE: Background startup of QEMU + guest verification
# VERSION: 2.1.0
# DEPENDS: uom-lib.sh, uom-qemu-phone, qemu-img, ssh
# SAFE: modifies-state (starts QEMU)
# TESTED: PASS 2026-07-18
#
# Termux:Widget background task. Runs on tap or Termux:Boot.
# Idempotent. Bounded retries. No root. Logs to ~/uom-vm/logs/widget-start-*.log.

set -u
. "${HOME}/bin/uom-widget-lib.sh"

UOM_DIR="${HOME}/src/universal-omni-master"
UOM_LOG_DIR="${HOME}/uom-vm/logs"
ZEN_TMUX_SESSION="uom-zen-phone"
SSH_READY_TIMEOUT=120

# ── Log file ───────────────────────────────────────────────────────────
mkdir -p "${UOM_LOG_DIR}"
_LOGFILE="${UOM_LOG_DIR}/widget-start-$(_uom_ts | tr ':' '-').log"
_log_start() { printf '[%s] [widget-start] %s\n' "$(_uom_ts)" "$*" | tee -a "${_LOGFILE}"; }

_log_start "=== Widget Start Begin ==="

# ── Acquire wake lock (best-effort) ────────────────────────────────────
if command -v termux-wake-lock >/dev/null 2>&1; then
    termux-wake-lock 2>/dev/null && _log_start "Wake lock acquired" || _log_start "Wake lock failed (non-fatal)"
else
    _log_start "termux-wake-lock not available (non-fatal)"
fi

# ── Validate disk ──────────────────────────────────────────────────────
DISK="${HOME}/uom-vm/images/uom-phone.qcow2"
if [ ! -f "${DISK}" ]; then
    _log_start "ERROR: No disk image at ${DISK}"
    _log_start "Run: ~/bin/uom-qemu-phone install"
    exit 1
fi
if ! qemu-img info "${DISK}" >/dev/null 2>&1; then
    _log_start "ERROR: Disk image corrupted: ${DISK}"
    exit 1
fi
_qsize=$(qemu-img info "${DISK}" 2>/dev/null | grep "disk size" | awk '{print $3, $4}')
_log_start "Disk OK: ${DISK} (${_qsize})"

# ── Start QEMU (idempotent — launcher handles already-running) ─────────
_log_start "Calling QEMU launcher start..."
"${UOM_QEMU_LAUNCHER}" start >> "${_LOGFILE}" 2>&1
_start_rc=$?
if [ "$_start_rc" -ne 0 ]; then
    _log_start "ERROR: QEMU launcher start returned rc=$_start_rc"
    exit 1
fi
_log_start "QEMU start command completed."

# ── Wait for guest SSH (bounded retries) ───────────────────────────────
_log_start "Waiting for guest SSH (timeout=${SSH_READY_TIMEOUT}s)..."
_count=0
while [ "${_count}" -lt "${SSH_READY_TIMEOUT}" ]; do
    if uom_guest_ssh 'echo OK' 2>/dev/null | grep -q "OK"; then
        _log_start "Guest SSH ready after ${_count}s"
        break
    fi
    sleep 3
    _count=$((_count + 3))
done
if [ "${_count}" -ge "${SSH_READY_TIMEOUT}" ]; then
    _log_start "ERROR: Guest SSH timeout after ${SSH_READY_TIMEOUT}s"
    _log_start "Check: ~/bin/uom-qemu-phone console"
    exit 1
fi

# ── Verify guest repo ──────────────────────────────────────────────────
if uom_guest_ssh "test -d ${UOM_DIR}/.git" 2>/dev/null; then
    _sha=$(uom_guest_ssh "cd ${UOM_DIR} && git rev-parse --short HEAD" 2>/dev/null || echo "unknown")
    _log_start "Guest repo OK (HEAD=${_sha})"
else
    _log_start "WARNING: Guest repo not found at ${UOM_DIR}"
fi

# ── Verify guest tmux ──────────────────────────────────────────────────
_guest_tmux=$(uom_guest_ssh "tmux ls 2>&1" 2>/dev/null || echo "none")
_log_start "Guest tmux: ${_guest_tmux}"

# ── Zen session status ─────────────────────────────────────────────────
if echo "${_guest_tmux}" | grep -q "${ZEN_TMUX_SESSION}"; then
    _log_start "Zen session '${ZEN_TMUX_SESSION}' already exists in guest."
else
    _log_start "Zen session not started (PRE-Phase-10)."
fi

# ── Summary ────────────────────────────────────────────────────────────
_log_start "=== Widget Start Complete ==="
_log_start "QEMU: running | Guest: SSH OK | Repo: verified"
_log_start "Log: ${_LOGFILE}"
