#!/bin/sh
# omni-storage — storage telemetry + filesystem management CLI
set -u

_OMNI_ROOT="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)"
. "$_OMNI_ROOT/src/core/logging.sh"
. "$_OMNI_ROOT/src/core/utils.sh"
. "$_OMNI_ROOT/src/core/priv.sh"
. "$_OMNI_ROOT/src/core/detect.sh"
. "$_OMNI_ROOT/src/storage/interface.sh"

USAGE="omni-storage <action> [args]
  -- Storage health --
  list                  enumerate block devices with type
  type <dev>            device type (nvme|ssd|hdd|sata|emmc|unknown)
  health <dev>          ok|degraded|critical|unknown
  mode [dev]            normal|cable_watch|rescue
  crc <dev>             SATA UDMA_CRC_Error_Count raw value
  attr <dev> <id>       SATA attribute RAW_VALUE by ID
  baseline <dev>        stored baseline
  nvme-cw <dev>         NVMe critical_warning hex
  nvme-cw-sev <dev>     NVMe critical_warning severity
  nvme-cw-explain <dev> decode warning bits
  luks <dev>            yes|no
  btrfs-subvols [mnt]   list Btrfs subvolumes
  btrfs-count [mnt]     count subvolumes
  btrfs-free [mnt]      unallocated bytes
  btrfs-device-stats [mnt]  per-counter health rows
  btrfs-device-health [mnt] ok|fail|critical
  btrfs-scrub [mnt]     ok|running|errors|no_scrub|unknown
  fsck-policy           print fsck invariant
  -- Filesystem detection --
  fs-type [mnt]         filesystem type of mountpoint (default: /)
  fs-root               filesystem type of / specifically
  fs-all                all mounted filesystems: mountpoint|type
  fs-device <dev>       filesystem type of block device
  fs-fstab-guide <fs>   print recommended fstab entry
  fs-btrfs-guide        print Btrfs subvolume creation guide
  fs-preference         show user filesystem preference
  -- Mutating (exit 126 under OMNI_SYSROOT) --
  set-baseline <dev>    persist current values as baseline
  fs-set-pref <fs>      set user filesystem preference (ext4|btrfs|xfs|f2fs|auto)"

[ $# -lt 1 ] && { printf '%s\n' "$USAGE" >&2; exit 2; }
ACTION="$1"; shift

case "$ACTION" in
    list)                storage_enumerate ;;
    type)                [ $# -ge 1 ] || { log_error "need device"; exit 2; }
                         storage_device_type "$1" ;;
    health)              [ $# -ge 1 ] || { log_error "need device"; exit 2; }
                         storage_health "$1" ;;
    mode)                cablewatch_mode "${1:-}" ;;
    crc)                 [ $# -ge 1 ] || { log_error "need device"; exit 2; }
                         smart_sata_crc "$1" ;;
    attr)                [ $# -ge 2 ] || { log_error "need device and attr ID"; exit 2; }
                         smart_sata_attr "$1" "$2" ;;
    baseline)            [ $# -ge 1 ] || { log_error "need device"; exit 2; }
                         smart_read_baseline "$1" ;;
    nvme-cw)             [ $# -ge 1 ] || { log_error "need device"; exit 2; }
                         smart_nvme_critical_warning "$1" ;;
    nvme-cw-sev)         [ $# -ge 1 ] || { log_error "need device"; exit 2; }
                         smart_nvme_cw_severity "$1" ;;
    nvme-cw-explain)     [ $# -ge 1 ] || { log_error "need device"; exit 2; }
                         smart_nvme_cw_explain "$1" ;;
    luks)                [ $# -ge 1 ] || { log_error "need device"; exit 2; }
                         storage_is_luks "$1" && echo yes || echo no ;;
    btrfs-subvols)       btrfs_list_subvolumes "${1:-/}" ;;
    btrfs-count)         btrfs_subvolume_count "${1:-/}" ;;
    btrfs-free)          btrfs_unallocated_bytes "${1:-/}" ;;
    btrfs-device-stats)  btrfs_device_stats "${1:-/}" ;;
    btrfs-device-health) btrfs_device_health "${1:-/}" ;;
    btrfs-scrub)         btrfs_scrub_last_status "${1:-/}" ;;
    fsck-policy)         cablewatch_fsck_policy ;;
    fs-type)             fs_detect_type "${1:-/}" ;;
    fs-root)             fs_root_type ;;
    fs-all)              fs_detect_all ;;
    fs-device)           [ $# -ge 1 ] || { log_error "need device"; exit 2; }
                         fs_device_type "$1" ;;
    fs-fstab-guide)      [ $# -ge 1 ] || { log_error "need fs type"; exit 2; }
                         fs_fstab_guide "$1" "${2:-}" "${3:-/}" ;;
    fs-btrfs-guide)      fs_btrfs_subvol_guide "${1:-}" ;;
    fs-preference)       fs_get_preference ;;
    set-baseline)        [ $# -ge 1 ] || { log_error "need device"; exit 2; }
                         [ -z "${OMNI_SYSROOT:-}" ] && prime_privileges
                         smart_set_baseline "$1" ;;
    fs-set-pref)         [ $# -ge 1 ] || { log_error "need fs type"; exit 2; }
                         [ -z "${OMNI_SYSROOT:-}" ] && prime_privileges
                         fs_set_preference "$1" ;;
    *)                   log_error "unknown action: $ACTION"; printf '%s\n' "$USAGE" >&2; exit 2 ;;
esac
