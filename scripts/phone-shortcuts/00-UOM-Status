#!/bin/sh
# NAME: 00-UOM-Status
# PURPOSE: Quick UOM system status check — shows QEMU, guest, tmux at a glance
# VERSION: 2.1.0
# DEPENDS: uom-lib.sh, uom-qemu-phone
# SAFE: read-only
# TESTED: PASS 2026-07-18
#
# Widget shortcut: tap to see system status. Read-only, idempotent.

set -u
. "${HOME}/bin/uom-widget-lib.sh"

echo "=========================================="
echo " UOM Status"
echo " $(_uom_ts)"
echo "=========================================="
echo ""

# QEMU status (via launcher 3-tier detection)
echo "--- QEMU ---"
"${UOM_QEMU_LAUNCHER}" status 2>/dev/null || echo "Status check failed"
echo ""

# Guest SSH
echo "--- Guest SSH ---"
if uom_guest_ssh 'echo OK' 2>/dev/null | grep -q "OK"; then
    echo "SSH:    OK"
    _info=$(uom_guest_ssh "hostname; id; uptime" 2>/dev/null || echo "info unavailable")
    echo "${_info}"
else
    echo "SSH:    UNREACHABLE"
fi
echo ""

# Guest tmux
echo "--- Guest tmux ---"
uom_guest_ssh "tmux ls 2>&1" 2>/dev/null || echo "(no tmux or guest unreachable)"
echo ""

# Host tmux
echo "--- Host tmux ---"
tmux ls 2>&1 || echo "(no host tmux sessions)"
echo ""

# Disk
echo "--- Disk ---"
qemu-img info "${HOME}/uom-vm/images/uom-phone.qcow2" 2>/dev/null | grep -E "virtual|disk size" || echo "(no disk)"
echo ""

# Processes
echo "--- Processes ---"
ps -A -o USER,PID,ARGS 2>/dev/null | grep -E "[q]emu|[o]pencode|[u]om-orch" || echo "(none found)"
echo ""

echo "=========================================="
