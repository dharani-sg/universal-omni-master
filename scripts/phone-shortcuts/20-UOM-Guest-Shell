#!/bin/sh
# NAME: 20-UOM-Guest-Shell
# PURPOSE: SSH into the Alpine guest — drops into interactive shell
# VERSION: 2.1.0
# DEPENDS: uom-lib.sh, uom-qemu-phone, ssh
# SAFE: modifies-state (starts QEMU if needed)
# TESTED: PASS 2026-07-18
#
# Widget shortcut: tap to enter guest shell. Preserves Ctrl-b d detach.

set -u
. "${HOME}/bin/uom-widget-lib.sh"

# Ensure QEMU is running (starts if needed)
if ! uom_ensure_qemu; then
    echo "[guest-shell] ERROR: QEMU not available"
    exit 1
fi

# Wait for SSH (bounded)
echo "[guest-shell] Waiting for guest SSH..."
_count=0
while [ "${_count}" -lt 120 ]; do
    if uom_guest_ssh 'echo OK' 2>/dev/null | grep -q "OK"; then
        break
    fi
    sleep 3
    _count=$((_count + 3))
done
if [ "${_count}" -ge 120 ]; then
    echo "[guest-shell] ERROR: Guest SSH timeout"
    exit 1
fi

# Interactive SSH shell
exec ssh -tt ${UOM_SSH_OPTS} ${UOM_GUEST_USER}@127.0.0.1
