# Build artifacts
_STAGE
omni-monolith.sh
*.tmp.*
/tmp/

# Large binary images — NEVER commit (power-loss safety)
*.img
*.raw
*.qcow2
*.dtb
*.dtbo
boot.img
initramfs
vmlinuz
linux.efi
*.bundle
uom-vm/

# Build work directories — large, never commit
uom-artifact-vault/
.mnt/
*.qcow2.*
qemu-*.log

# Artifact vault for pmOS builds
uom-artifact-vault/

# Recovery state with large references
.uom-agent/recovery/post-powerloss-*
# Editor/OS noise
*.swp
*~
.DS_Store
# Foreign project / fixture runtime — never track
omni-master-core
sandbox/run/

# Stray files from accidental shell commands
-X

# UOM dual-agent state (tracked)
!.uom-agent/
!.uom-agent/**

# Secrets — never track
.env
*.env
secrets.env
.config/uom/secrets.env
*.key
*.pem
*.p12
.uom-agent/session_key
.uom-agent/locks/
.uom-agent/logs/
.uom-agent/runtime/
.uom-agent/feedback/
.uom-agent/generated/
.uom-agent/verified/
.uom-agent/burnin-output.log
.uom-agent/burnin-summary.json
.uom-agent/test-llm-output.txt
.uom-agent/*.host
.uom-termux-user/
.install-gate-evidence/
__pycache__/
