[Unit]
Description=Universal Omni-Master Self-Healing Watchdog
After=local-fs.target network.target
Wants=dbus.service

[Service]
Type=simple
ExecStart=/usr/bin/omni-healer run
ExecStop=/usr/bin/omni-healer stop
Restart=on-failure
RestartSec=5
PIDFile=/run/omni-healer.pid

[Install]
WantedBy=multi-user.target
