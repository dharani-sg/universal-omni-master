#!/bin/sh
# omni-deploy — Universal Omni-Master deployment orchestrator.
# Default mode: dry-run. Use --apply to execute changes.
set -u

_OMNI_ROOT="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)"

. "$_OMNI_ROOT/src/core/logging.sh"
. "$_OMNI_ROOT/src/core/utils.sh"
. "$_OMNI_ROOT/src/core/priv.sh"
. "$_OMNI_ROOT/src/core/detect.sh"
. "$_OMNI_ROOT/src/core/detect_hw.sh"
. "$_OMNI_ROOT/src/gpu/interface.sh"     2>/dev/null || true
. "$_OMNI_ROOT/src/storage/interface.sh" 2>/dev/null || true

. "$_OMNI_ROOT/src/deploy/common.sh"
. "$_OMNI_ROOT/src/deploy/state.sh"
. "$_OMNI_ROOT/src/deploy/preflight.sh"
. "$_OMNI_ROOT/src/deploy/chroot.sh"
. "$_OMNI_ROOT/src/deploy/partition.sh"
. "$_OMNI_ROOT/src/deploy/bootstrap.sh"
. "$_OMNI_ROOT/src/deploy/configure.sh"
. "$_OMNI_ROOT/src/deploy/bootloader.sh"
. "$_OMNI_ROOT/src/deploy/rollback.sh"
. "$_OMNI_ROOT/src/deploy/healer_install.sh"
. "$_OMNI_ROOT/src/deploy/snapshot_install.sh"
. "$_OMNI_ROOT/src/deploy/remote.sh"
. "$_OMNI_ROOT/src/deploy/verify.sh"
. "$_OMNI_ROOT/src/deploy/orchestrate.sh"

# ── Defaults ──────────────────────────────────────────────────────────────────
DEPLOY_DRYRUN=1
DEPLOY_DISTRO="${DEPLOY_DISTRO:-}"
DEPLOY_FS="${DEPLOY_FS:-btrfs}"
DEPLOY_DISK="${DEPLOY_DISK:-}"
DEPLOY_TARGET="${DEPLOY_TARGET:-/mnt}"
DEPLOY_INIT="${DEPLOY_INIT:-}"
DEPLOY_ENCRYPT="${DEPLOY_ENCRYPT:-0}"
DEPLOY_HOSTNAME="${DEPLOY_HOSTNAME:-omni-linux}"
DEPLOY_USER="${DEPLOY_USER:-}"
DEPLOY_LOCALE="${DEPLOY_LOCALE:-en_US.UTF-8}"
DEPLOY_DESKTOP="${DEPLOY_DESKTOP:-}"
DEPLOY_DESKTOP_USER="${DEPLOY_DESKTOP_USER:-}"
DEPLOY_LOGIN_MANAGER="${DEPLOY_LOGIN_MANAGER:-auto}"
DEPLOY_ALLOW_EXPERIMENTAL_DESKTOP="${DEPLOY_ALLOW_EXPERIMENTAL_DESKTOP:-0}" 
DEPLOY_RESUME="${DEPLOY_RESUME:-0}"
DEPLOY_FRESH="${DEPLOY_FRESH:-0}"

COMMAND="${1:-help}"
[ $# -gt 0 ] && shift

while [ $# -gt 0 ]; do
    case "$1" in
        --apply)      DEPLOY_DRYRUN=0 ;;
        --resume)     DEPLOY_RESUME=1 ;;
        --fresh)      DEPLOY_FRESH=1 ;;
        --desktop) shift; DEPLOY_DESKTOP="${1:-}" ;;
        --desktop-user) shift; DEPLOY_DESKTOP_USER="${1:-}" ;;
        --login-manager) shift; DEPLOY_LOGIN_MANAGER="${1:-auto}" ;;
        --allow-experimental-desktop) DEPLOY_ALLOW_EXPERIMENTAL_DESKTOP=1 ;;
        --distro)     shift; DEPLOY_DISTRO="$1" ;;
        --fs)         shift; DEPLOY_FS="$1" ;;
        --disk)       shift; DEPLOY_DISK="$1" ;;
        --target)     shift; DEPLOY_TARGET="$1" ;;
        --init)       shift; DEPLOY_INIT="$1" ;;
        --hostname)   shift; DEPLOY_HOSTNAME="$1" ;;
        --user)       shift; DEPLOY_USER="$1" ;;
        --encrypt)    DEPLOY_ENCRYPT=1 ;;
        *) log_error "Unknown: $1"; exit 2 ;;
    esac
    shift
done

export DEPLOY_TARGET DEPLOY_DISK DEPLOY_FS DEPLOY_DISTRO DEPLOY_INIT
export DEPLOY_ENCRYPT DEPLOY_HOSTNAME DEPLOY_USER DEPLOY_DRYRUN DEPLOY_LOCALE
export DEPLOY_RESUME DEPLOY_FRESH
export DEPLOY_DESKTOP DEPLOY_DESKTOP_USER DEPLOY_LOGIN_MANAGER DEPLOY_ALLOW_EXPERIMENTAL_DESKTOP

# ── Dispatch ──────────────────────────────────────────────────────────────────
case "$COMMAND" in
    help|--help|-h)
        cat << HELP
omni-deploy — Universal Omni-Master Installer

Usage: omni-deploy <command> [options]

Commands:
  plan        Show deployment plan without executing
  preflight   Run hardware compatibility checks only
  install     Full install (all phases)
  rollback    Undo a failed installation
  status      Show current phase state
  help        Show this help

Options:
  --apply       Execute changes (default: dry-run, prints only)
  --resume      Resume a matching interrupted deployment
  --fresh       Discard interrupted state and start a fresh deployment
  --distro N    $(deploy_list_distros | tr '\n' '|' | sed 's/|$//')
  --fs T        ext4|btrfs|xfs|f2fs (default: btrfs)
  --disk D      target disk, e.g. sda or nvme0n1
  --init I      $(deploy_list_inits | tr '\n' '|' | sed 's/|$//')
  --hostname N  hostname (default: omni-linux)
  --user N      create non-root user
  --encrypt     enable LUKS2 full-disk encryption
  --target DIR  mount point (default: /mnt)
HELP
        exit 0
        ;;

    plan)
        printf '\n══ DEPLOYMENT PLAN ══\n'
        printf '  distro:     %s\n' "${DEPLOY_DISTRO:-<not set>}"
        printf '  filesystem: %s\n' "$DEPLOY_FS"
        printf '  disk:       %s\n' "${DEPLOY_DISK:-<not set>}"
        printf '  init:       %s\n' "${DEPLOY_INIT:-<auto-detect>}"
        printf '  encrypt:    %s\n' "$DEPLOY_ENCRYPT"
        printf '  hostname:   %s\n' "$DEPLOY_HOSTNAME"
        printf '  target:     %s\n' "$DEPLOY_TARGET"
        printf '  mode:       %s\n' "$([ "$DEPLOY_DRYRUN" -eq 1 ] && echo DRY-RUN || echo APPLY)"
        printf '  root fs:    %s\n' "$(fs_root_type 2>/dev/null || echo unknown)"
        printf '  GPU hybrid: %s\n' "$(detect_gpu_hybrid 2>/dev/null || echo unknown)"
        preflight_check 2>/dev/null || true
        exit 0
        ;;

    preflight)
        preflight_check
        ;;

    status)
        deploy_state_summary
        ;;

    rollback)
        rollback_full "$DEPLOY_TARGET"
        ;;

    install)
        printf '\n══════════════════════════════════════\n'
        printf '  Universal Omni-Master — Installation\n'
        printf '══════════════════════════════════════\n'

        [ "$DEPLOY_DRYRUN" -eq 1 ] && \
            printf '\n[DRY-RUN] No changes will be made. Use --apply.\n\n'

        # Interactive selection
        if [ -z "$DEPLOY_DISTRO" ]; then
            printf '\nSelect distribution:\n'; deploy_list_distros
            printf 'Choice: '; read -r DEPLOY_DISTRO
        fi
        if [ -z "$DEPLOY_DISK" ]; then
            printf '\nAvailable disks:\n'
            storage_enumerate 2>/dev/null || lsblk -d -o NAME,SIZE 2>/dev/null
            printf 'Target disk (e.g. sda): '; read -r DEPLOY_DISK
        fi
        if [ -z "$DEPLOY_INIT" ]; then
            DEPLOY_INIT=$(deploy_auto_detect_init "$DEPLOY_DISTRO")
            log_info "Auto-detected init: $DEPLOY_INIT"
        fi

        # Plan display
        printf '\n══ PLAN ══\n'
        printf '  Distro:     %s (init: %s)\n' "$DEPLOY_DISTRO" "$DEPLOY_INIT"
        printf '  Filesystem: %s\n' "$DEPLOY_FS"
        printf '  Disk:       /dev/%s\n' "$DEPLOY_DISK"
        printf '  Encrypt:    %s\n' "$DEPLOY_ENCRYPT"
        printf '  Hostname:   %s\n' "$DEPLOY_HOSTNAME"

        [ "$DEPLOY_DRYRUN" -eq 1 ] && { printf '\n[DRY-RUN] Remove --apply to exit.\n'; exit 0; }

        deploy_install_execute
        exit $?
        ;;

    *)
        log_error "Unknown command: $COMMAND"
        exit 2
        ;;
esac
