#!/usr/bin/env python3
"""
Omni Status - UOM Project Status Monitor
Shows comprehensive status of UOM hybrid orchestration system
"""

import subprocess
import sys
import os
import json
import time
from pathlib import Path

# Colors for output
RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
BLUE = "\033[0;34m"
CYAN = "\033[0;36m"
NC = "\033[0m"


def run_cmd(cmd):
    """Run command and return output"""
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=10)
        return result.returncode == 0, result.stdout.strip(), result.stderr.strip()
    except:
        return False, "", "Command failed"


def get_timestamp():
    """Get formatted timestamp"""
    return time.strftime("%Y-%m-%d %H:%M:%S IST")


def print_header():
    """Print report header"""
    print("=" * 80)
    print(f"UOM PROJECT STATUS - {get_timestamp()}")
    print("=" * 80)
    print()


def load_state():
    """Load state.json file"""
    state_file = Path("/home/alpine/src/universal-omni-master/.uom-agent/state.json")
    if not state_file.exists():
        print(f"{RED}✗ State file not found: {state_file}{NC}")
        return {}

    try:
        with open(state_file, 'r') as f:
            return json.load(f)
    except Exception as e:
        print(f"{RED}✗ Error loading state file: {e}{NC}")
        return {}


def print_system_status(state):
    """Print current system status"""
    print("System Status:")
    hybrid_mode = state.get("hybrid_mode", "dual")
    active_agent = state.get("active_agent", "unknown")
    task_status = state.get("task_status", "idle")
    current_task = state.get("current_task_id", "none")
    takeover_count = state.get("takeover_count", 0)

    # Show mode with color
    if hybrid_mode == "dual":
        mode_str = f"{GREEN}✓ DUAL{NC}"
    elif hybrid_mode == "solo":
        mode_str = f"{YELLOW}⚠ SOLO{NC}"
    else:
        mode_str = f"{CYAN}{hybrid_mode.upper()}{NC}"

    print(f"  Mode: {mode_str} (Agent: {active_agent})")
    print(f"  Task: {current_task} ({task_status})")
    print(f"  Takeovers: {takeover_count}")
    print()


def check_processes():
    """Check running orchestrator processes"""
    print("Running Processes:")

    processes = [
        ("uom-orch-laptop", "Laptop Orchestrator"),
        ("uom-orch-phone", "Phone Orchestrator"),
        ("uom-solo-orchestrator", "Solo Orchestrator"),
    ]

    for pattern, name in processes:
        success, out, err = run_cmd(f"ps -ef | grep -v grep | grep -q '{pattern}' && echo 'RUNNING' || echo 'STOPPED'")
        if out == "RUNNING":
            print(f"  {GREEN}✓ {name}{NC}")
        else:
            print(f"  {RED}✗ {name}{NC}")

    print()


def check_ssh_tunnel():
    """Check reverse tunnel status"""
    print("Reverse Tunnel:")
    success, out, err = run_cmd("ssh -o ConnectTimeout=3 -o BatchMode=yes -p 18022 127.0.0.1 true 2>/dev/null && echo 'UP' || echo 'DOWN'")
    if out == "UP":
        print(f"  {GREEN}✓ UP{NC} (laptop → phone:18022)")
    else:
        print(f"  {RED}✗ DOWN{NC}")
        # Check if tunnel process exists
        hyb_dir = Path.home() / ".uom-termux-user"
        pid_file = hyb_dir / "tunnel.pid"
        if pid_file.exists():
            with open(pid_file, 'r') as f:
                pid = f.read().strip()
            success, out, err = run_cmd(f"ps -p {pid} >/dev/null 2>&1 && echo 'RUNNING' || echo 'STOPPED'")
            if out == "RUNNING":
                print(f"    Process: {GREEN}RUNNING{NC} (PID: {pid})")
            else:
                print(f"    Process: {YELLOW}STOPPED{NC}")
    print()


def get_log_tail(log_path):
    """Get last line of log file"""
    if log_path.exists():
        success, out, err = run_cmd(f"tail -n 3 '{log_path}' 2>/dev/null | tail -1")
        if out:
            return out
    return None


def print_logs():
    """Print recent logs"""
    print("Recent Logs:")

    # Omni orchestrator log
    log_file = Path.home() / ".uom-termux-user" / "omni-orchestrator.log"
    if log_file.exists():
        line = get_log_tail(log_file)
        if line:
            print(f"  Omni: {CYAN}{line}{NC}")
        else:
            print(f"  Omni: {YELLOW}No recent logs{NC}")
    else:
        print(f"  Omni: {YELLOW}Not found{NC}")

    # Tunnel log
    tunnel_log = Path.home() / ".uom-termux-user" / "tunnel.log"
    if tunnel_log.exists():
        line = get_log_tail(tunnel_log)
        if line:
            print(f"  Tunnel: {CYAN}{line}{NC}")
        else:
            print(f"  Tunnel: {YELLOW}No recent logs{NC}")
    else:
        print(f"  Tunnel: {YELLOW}Not found{NC}")

    print()


def print_files():
    """Print system file status"""
    print("System Files:")

    state_file = Path("/home/alpine/src/universal-omni-master/.uom-agent/state.json")
    if state_file.exists():
        print(f"  {GREEN}✓ state.json{NC}")
    else:
        print(f"  {RED}✗ state.json{NC}")

    queue_file = Path("/home/alpine/src/universal-omni-master/.uom-agent/queue.json")
    if queue_file.exists():
        print(f"  {GREEN}✓ queue.json{NC}")
    else:
        print(f"  {RED}✗ queue.json{NC}")

    # Check PID files
    hyb_dir = Path.home() / ".uom-termux-user"
    if hyb_dir.exists():
        pid_files = list(hyb_dir.glob("*.pid"))
        print(f"  {GREEN}✓ .uom-termux-user/ directory ({len(pid_files)} PID files){NC}")
    else:
        print(f"  {RED}✗ .uom-termux-user/{NC}")

    print()


def print_queue():
    """Print task queue"""
    print("Task Queue:")

    queue_file = Path("/home/alpine/src/universal-omni-master/.uom-agent/queue.json")
    if queue_file.exists():
        try:
            with open(queue_file, 'r') as f:
                queue = json.load(f)

            pending = [t for t in queue if t.get('status') == 'pending']
            failed = [t for t in queue if t.get('status') == 'failed']

            print(f"  Total: {len(queue)}")
            print(f"  {GREEN}✓ Pending: {len(pending)}{NC}")
            if failed:
                print(f"  {RED}✗ Failed: {len(failed)}{NC}")
                for task in failed[:2]:  # Show first 2 failed tasks
                    print(f"    - {task.get('id', 'unknown')}: {task.get('desc', '')}")
        except Exception as e:
            print(f"  {RED}✗ Error: {e}{NC}")
    else:
        print(f"  {RED}✗ Queue not found{NC}")

    print()


def print_commands():
    """Print available commands"""
    print("Available Commands:")
    print("=" * 80)
    print(f"  {CYAN}omni-project-status{NC}          - Show status (default)")
    print(f"  {CYAN}omni-project-status --full{NC}    - Show status + logs")
    print(f"  {CYAN}omni-project-status --status{NC}   - Quick status only")
    print(f"  {CYAN}omni-project-status tunnel{NC}    - Check tunnel")
    print(f"  {CYAN}omni-project-status current{NC}   - Show mode")
    print(f"  {CYAN}uom-status{NC}                    - UOM shortcut")
    print("=" * 80)
    print()


def main():
    """Main function"""
    print_header()
    state = load_state()

    print_system_status(state)
    check_processes()
    check_ssh_tunnel()
    print_logs()
    print_files()
    print_queue()
    print_commands()


if __name__ == "__main__":
    main()
