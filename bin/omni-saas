#!/bin/sh
# bin/omni-saas — M23: SaaS metering and license CLI.
set -u

_OMNI_ROOT="${OMNI_ROOT:-$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)}"
. "$_OMNI_ROOT/src/saas/meter.sh"

_usage() {
    cat << HELP
omni-saas — SaaS License & Metering

Usage: omni-saas <command> [args]

Commands:
  validate <key>    Validate license key with offline grace cache
  meter <event>     Record and optionally upload usage event
  help              Show this message
HELP
}

COMMAND="${1:-help}"
[ $# -gt 0 ] && shift || true

case "$COMMAND" in
    validate)
        saas_check_license "${1:?license key required}" ;;
    meter)
        saas_meter_event "${1:?event required}" ;;
    help|--help|-h)
        _usage; exit 0 ;;
    *)
        printf 'omni-saas: unknown command: %s\n' "$COMMAND" >&2
        _usage >&2
        exit 2 ;;
esac
